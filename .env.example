# OpenAI API key used by LangChain
OPENAI_API_KEY=

# Default model for the Tutor platform
LLM_MODEL=gpt-5.4-mini

# Sampling control for deterministic responses
LLM_TEMPERATURE=0

# LangSmith tracing configuration
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# PostgreSQL connection string (async driver — required for SQLAlchemy AsyncEngine)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tutor_platform

# Log every SQL statement emitted by SQLAlchemy (verbose — keep false in production)
DB_ECHO=false

# Connection pool sizing
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
